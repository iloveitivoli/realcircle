# 真人圈 RealCircle — 环境变量示例(复制为 .env 并按需修改)
PORT=3000
NODE_ENV=production
ADMIN_PHONE=13800000001
# CORS_ORIGIN=https://your-domain.com

# ===== 存储:json(默认,零依赖)| postgres =====
STORAGE=json
DATA_FILE=./data.json
# 切换到 PostgreSQL(需 `npm install pg`):
# STORAGE=postgres
# DATABASE_URL=postgres://realcircle:realcircle@localhost:5432/realcircle
# PG_POOL_MAX=10
# PG_SSL=false          # 托管云库(RDS/Supabase 等)通常需设为 true

# ===== 活体验证 provider:mock(默认)| facetec | iproov =====
LIVENESS_PROVIDER=mock
# FaceTec(海外金融级):
# FACETEC_API_URL=https://your-facetec-endpoint
# FACETEC_API_KEY=...
# iProov:
# IPROOV_API_URL=https://eu.rp.secure.iproov.me
# IPROOV_API_KEY=...
# IPROOV_API_SECRET=...
